    {
    "title": "CPU Usage (%)",
    "type": "gauge",
    "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
    "datasource": { "type": "prometheus", "uid": "prometheus" },
    "targets": [
    {
    "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
    "legendFormat": "CPU %"
    }
    ],
    "fieldConfig": {
    "defaults": {
    "thresholds": {
    "mode": "absolute",
    "steps": [
    { "color": "green", "value": null },
    { "color": "yellow", "value": 50 },
    { "color": "red", "value": 75 }
    ]
    },
    "max": 100,
    "min": 0,
    "unit": "percent"
    }
    }
    },
